{
  "name": "synaptic-sentinel-dev",
  "version": "0.0.0",
  "private": true,
  "description": "Synaptic Sentinel — monorepo de desarrollo (OSS + Pro). Toolkit de auditoria agentica de seguridad para la era del vibe-coding.",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc -b && pnpm --filter @synaptic-sentinel/vscode-extension bundle",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b && tsc -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm format:check && pnpm lint && pnpm build && pnpm test:unit",
    "scanners:install": "node --use-system-ca scripts/install-scanners.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
