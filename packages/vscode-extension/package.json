{
  "name": "synaptic-sentinel",
  "displayName": "Synaptic Sentinel",
  "version": "0.1.0",
  "description": "Agentic security auditing for the era of AI-generated code. Five scouts (OpenGrep, Gitleaks, Trivy, Checkov, Vibe-Detect) + a Brain Layer that triages, explains and remediates — all in the IDE, BYOK.",
  "license": "Apache-2.0",
  "private": true,
  "publisher": "RealGoLab",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=20"
  },
  "categories": [
    "Linters",
    "Testing",
    "Other"
  ],
  "keywords": [
    "synaptic",
    "security",
    "sast",
    "taint-analysis",
    "sarif",
    "code-scanning",
    "vibe-coding",
    "ai-coding",
    "appsec",
    "byok"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/golab-arch/synaptic-sentinel.git",
    "directory": "packages/vscode-extension"
  },
  "homepage": "https://github.com/golab-arch/synaptic-sentinel#readme",
  "bugs": {
    "url": "https://github.com/golab-arch/synaptic-sentinel/issues"
  },
  "main": "./dist/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "synaptic-sentinel.scanWorkspace",
        "title": "Scan Workspace",
        "category": "Synaptic Sentinel"
      },
      {
        "command": "synaptic-sentinel.triageWorkspace",
        "title": "Triage Findings (Brain Layer)",
        "category": "Synaptic Sentinel"
      },
      {
        "command": "synaptic-sentinel.setAnthropicApiKey",
        "title": "Set Anthropic API Key (BYOK)",
        "category": "Synaptic Sentinel"
      },
      {
        "command": "synaptic-sentinel.installScanners",
        "title": "Install Scanners",
        "category": "Synaptic Sentinel"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "synaptic-sentinel.tomo",
          "name": "Synaptic Sentinel",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Synaptic Sentinel",
      "properties": {
        "synaptic-sentinel.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the CLI entry (cli/dist/index.js). Empty = resolved next to the extension."
        }
      }
    }
  },
  "scripts": {
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --outfile=dist/extension.cjs --sourcemap && esbuild ../cli/src/index.ts --bundle --platform=node --format=esm --target=node20 --external:node-sqlite3-wasm --external:@anthropic-ai/sdk --outfile=dist/cli.mjs --sourcemap && node scripts/copy-cli-assets.mjs",
    "vscode:prepublish": "pnpm -w run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "node-sqlite3-wasm": "^0.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0"
  }
}
