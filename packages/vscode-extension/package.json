{
  "name": "synaptic-sentinel",
  "displayName": "SYNAPTIC Sentinel",
  "version": "0.3.16",
  "description": "The vibe-coding security sentinel. Apache-2.0 agentic auditing for AI-assisted projects: five scouts (OpenGrep, Gitleaks, Trivy, Checkov, Vibe-Detect) + a Brain Layer (BYOK Anthropic) that triages, explains and remediates — all in the IDE.",
  "license": "Apache-2.0",
  "private": true,
  "publisher": "RealGoLab",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=20"
  },
  "categories": [
    "Linters",
    "Testing",
    "Other"
  ],
  "keywords": [
    "synaptic",
    "security",
    "sast",
    "taint-analysis",
    "sarif",
    "code-scanning",
    "vibe-coding",
    "ai-coding",
    "ai-generated-code",
    "llm-security",
    "appsec",
    "byok"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/golab-arch/synaptic-sentinel.git",
    "directory": "packages/vscode-extension"
  },
  "homepage": "https://github.com/golab-arch/synaptic-sentinel#readme",
  "bugs": {
    "url": "https://github.com/golab-arch/synaptic-sentinel/issues"
  },
  "main": "./dist/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "synaptic-sentinel.scanWorkspace",
        "title": "Scan Workspace",
        "category": "SYNAPTIC Sentinel"
      },
      {
        "command": "synaptic-sentinel.triageWorkspace",
        "title": "Triage Findings (Brain Layer)",
        "category": "SYNAPTIC Sentinel"
      },
      {
        "command": "synaptic-sentinel.setAnthropicApiKey",
        "title": "Set Anthropic API Key (BYOK)",
        "category": "SYNAPTIC Sentinel"
      },
      {
        "command": "synaptic-sentinel.installScanners",
        "title": "Install Scanners",
        "category": "SYNAPTIC Sentinel"
      },
      {
        "command": "synaptic-sentinel.configureProviders",
        "title": "Configure Brain Layer Providers",
        "category": "SYNAPTIC Sentinel"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "synaptic-sentinel.tomo",
          "name": "SYNAPTIC Sentinel",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "SYNAPTIC Sentinel",
      "properties": {
        "synaptic-sentinel.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the CLI entry (cli/dist/index.js). Empty = resolved next to the extension."
        },
        "synaptic-sentinel.triageLimit": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum number of pending findings the Brain Layer will triage in a single 'Triage Findings' run. Findings beyond this cap stay 'untriaged'; click 'Triage Remaining' in the sidebar to triage them in a follow-up run. Default 25 limits cost on the first run; raise it if your workspace has more findings and you want them all triaged at once."
        }
      }
    }
  },
  "scripts": {
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --external:node-sqlite3-wasm --external:@anthropic-ai/sdk --external:openai --outfile=dist/extension.cjs --sourcemap && esbuild ../cli/src/index.ts --bundle --platform=node --format=esm --target=node20 --external:node-sqlite3-wasm --external:@anthropic-ai/sdk --external:openai --outfile=dist/cli.mjs --sourcemap && node scripts/copy-cli-assets.mjs",
    "vscode:prepublish": "pnpm -w run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@synaptic-sentinel/agents": "workspace:*",
    "@synaptic-sentinel/core": "workspace:*",
    "js-yaml": "^4.1.0",
    "node-sqlite3-wasm": "^0.8.0",
    "openai": "^6.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0"
  }
}
